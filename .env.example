GONKA_API_KEY=replace_with_your_gonka_api_key
GONKA_BASE_URL=https://api.gonkarouter.io/v1
GONKA_MODEL=auto
# Gonka 目前 /chat/completions 只实际服务 MiniMaxAI/MiniMax-M2.7；
# moonshotai/Kimi-K2.6 虽在 /models 列出，但调用会返回 400 unsupported model。
# 因此校验员也指向 MiniMax，走同模型双通道独立校验（两次真实独立调用）。
# 一旦 Gonka 恢复第二个模型，把 GONKA_VERIFIER_MODEL 指回它即可恢复真正的双模型。
GONKA_ARCHAEOLOGIST_MODEL=MiniMaxAI/MiniMax-M2.7
GONKA_VERIFIER_MODEL=MiniMaxAI/MiniMax-M2.7
GONKA_MODEL_PREFERENCE=MiniMaxAI/MiniMax-M2.7
GONKA_TIMEOUT_SECONDS=35
GONKA_MAX_TOKENS=1024

# Required on Vercel so verification receipts remain valid across functions.
VERIFICATION_SIGNING_SECRET=replace_with_at_least_16_random_characters
VERIFICATION_CACHE_DIR=

# Optional. If set, "生成永久档案" uploads the sealed JSON to IPFS through Pinata.
PINATA_JWT=replace_with_your_pinata_jwt
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/
